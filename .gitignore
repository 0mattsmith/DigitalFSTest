# Node.js
node_modules/
package-lock.json

# Build output
dist/

# Don't gitignore build/ — it holds the icon master assets (icon.png,
# icon-192.png, icon-512.png, icon-maskable-512.png, icon.ico). These
# need to be committed so the GitHub Actions workflow can copy them
# into docs/ when it builds the site.
# build/  ← intentionally NOT ignored

# Per-user data — student attempts and history should never be committed
user-data/
attempts/

# OS junk
.DS_Store
Thumbs.db
ehthumbs.db

# Editor / IDE
.vscode/
.idea/
*.swp
*.swo
.cursorrules

# Logs
*.log
npm-debug.log*

# Personal access tokens or env files — never commit these
.env
.env.*
*.pem
*.key

# Firebase Web App config IS safe to commit (apiKey etc. are public —
# security comes from Firestore Security Rules in firestore.rules).
# Keep the file tracked so the GitHub Actions deploy can use it.
# web/firebase-config.js  ← intentionally NOT ignored

